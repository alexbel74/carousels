# =============================================================================
# Carousel Pro — пример конфигурации
# Скопировать в .env и заполнить значения. ФАЙЛ .env В GIT НЕ КОММИТИТСЯ.
# =============================================================================

# ----- Прокси для Gemini API -----
# Используется backend'ом для обхода геоблока (РФ → Google API).
# Формат: http://username:password@host:port
# Если оставить пустым — запросы идут напрямую (только если у тебя VPS не под санкциями).
PROXY_URL=

# ----- Backend порт (опционально) -----
# По умолчанию backend слушает 3001 внутри docker-сети.
# Менять не нужно, если не знаешь что делаешь.
# PORT=3001
